---
import ResponsiveLayout from '../../components/layout/ResponsiveLayout.jsx';
import SubmissionOverview from '../../components/SubmissionOverview.jsx';
import '../../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Submission Overview | UCO Media Request System</title>
</head>
<body class="bg-slate-50 dark:bg-slate-950 transition-colors duration-300">
  <ResponsiveLayout client:load>
    <div class="mb-6">
      <a href="/history" class="group inline-flex items-center gap-2 text-xs font-bold text-slate-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors uppercase tracking-widest">
        <span class="w-8 h-8 flex items-center justify-center bg-white dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-800 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-950/30 group-hover:border-indigo-100 dark:group-hover:border-indigo-900 transition-all">←</span>
        Back to My Requests
      </a>
    </div>
    
    <SubmissionOverview client:load />
  </ResponsiveLayout>
</body>
</html>
